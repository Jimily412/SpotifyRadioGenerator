{
  "name": "tasteengine",
  "version": "1.0.0",
  "description": "Personal Spotify AI playlist generator",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "webpack --config webpack.config.js && electron-builder",
    "build:win": "webpack --config webpack.config.js && electron-builder --win",
    "build:mac": "webpack --config webpack.config.js && electron-builder --mac",
    "build:linux": "webpack --config webpack.config.js && electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.8",
    "ml-kmeans": "^3.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.2",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "com.tasteengine.app",
    "productName": "TasteEngine",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "protocols": [
      {
        "name": "TasteEngine",
        "schemes": [
          "tasteengine"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Jimily412",
      "repo": "SpotifyRadioGenerator"
    }
  }
}
