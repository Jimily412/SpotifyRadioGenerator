{
  "name": "tasteengine",
  "version": "1.0.0",
  "description": "Personal Spotify AI Playlist Generator",
  "main": "main/index.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "dev": "concurrently \"webpack --watch --mode development\" \"wait-on dist/renderer/index.html && electron .\"",
    "build:renderer": "webpack --mode production",
    "build": "webpack --mode production",
    "dist": "electron-builder",
    "postinstall": "node scripts/create-icon.js"
  },
  "build": {
    "appId": "com.tasteengine.app",
    "productName": "TasteEngine",
    "directories": {
      "output": "release"
    },
    "files": [
      "main/**/*",
      "dist/renderer/**/*",
      "assets/**/*"
    ],
    "protocols": [
      {
        "name": "TasteEngine",
        "schemes": [
          "tasteengine"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "jimily412",
      "repo": "spotifyradiogenerator"
    }
  },
  "dependencies": {
    "axios": "^1.6.8",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7",
    "ml-kmeans": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  }
}
